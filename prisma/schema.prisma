// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  MANAGER
  EMPLOYEE
}

enum Status {
  ACTIVE
  INACTIVE
}

enum TwoFactorType {
  NONE
  EMAIL
  GOOGLE_AUTHENTICATOR
}

model Employee {
  id                String        @id @default(uuid())
  username          String        @unique
  email             String        @unique
  password          String
  name              String
  role              Role          @default(EMPLOYEE)
  is2FAEnabled      Boolean       @default(false)
  twoFactorSecret   String?
  twoFactorType     TwoFactorType @default(NONE)
  
  // Security
  isLocked          Boolean       @default(false)
  failedAttempts    Int           @default(0)
  lockUntil         DateTime?
  status            Status        @default(ACTIVE)

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Member {
  id              String   @id @default(uuid())
  memberId        String   @unique
  name            String
  email           String?  @unique
  phone           String?
  password        String
  
  // Balances
  shareAccountNo  String?  @unique
  shareBalance    Decimal  @default(0.0) @db.Decimal(15, 2)
  depositBalance  Decimal  @default(0.0) @db.Decimal(15, 2)
  loanBalance     Decimal  @default(0.0) @db.Decimal(15, 2)
  
  status          Status   @default(ACTIVE)

  deposits        DepositAccount[]
  loans           LoanAccount[]
  loanApps        LoanApplication[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum DepositType {
  SAVINGS
  FIXED
  DOUBLE_DEPOSIT
  PENSION
}

model DepositAccount {
  id              String      @id @default(uuid())
  accountNumber   String      @unique
  type            DepositType
  balance         Decimal     @default(0.0) @db.Decimal(15, 2)
  interestRate    Decimal     @db.Decimal(5, 2)
  maturityDate    DateTime?
  
  memberId        String
  member          Member      @relation(fields: [memberId], references: [id])

  createdAt       DateTime    @default(now())
}

enum LoanStatus {
  ACTIVE
  CLOSED
}

model LoanAccount {
  id              String      @id @default(uuid())
  accountNumber   String      @unique
  type            String
  principal       Decimal     @db.Decimal(15, 2)
  interestRate    Decimal     @db.Decimal(5, 2)
  balance         Decimal     @db.Decimal(15, 2)
  tenureMonths    Int
  monthlyEMI      Decimal     @db.Decimal(15, 2)
  status          LoanStatus  @default(ACTIVE)
  startDate       DateTime
  
  memberId        String
  member          Member      @relation(fields: [memberId], references: [id])

  schedules       EMISchedule[]

  createdAt       DateTime    @default(now())
}

enum AppStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model LoanApplication {
  id              String      @id @default(uuid())
  type            String
  amount          Decimal     @db.Decimal(15, 2)
  tenureMonths    Int
  interestRate    Decimal     @db.Decimal(5, 2)
  status          AppStatus   @default(PENDING)
  documents       String      @db.LongText // JSON array of document URLs
  remarks         String?     @db.Text
  
  memberId        String
  member          Member      @relation(fields: [memberId], references: [id])

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum EMIStatus {
  PAID
  UNPAID
}

model EMISchedule {
  id              String      @id @default(uuid())
  dueDate         DateTime
  amount          Decimal     @db.Decimal(15, 2)
  principal       Decimal     @db.Decimal(15, 2)
  interest        Decimal     @db.Decimal(15, 2)
  status          EMIStatus   @default(UNPAID)
  
  loanAccountId   String
  loanAccount     LoanAccount @relation(fields: [loanAccountId], references: [id])
}

enum OTPType {
  FORGOT_PASSWORD
  TWO_FACTOR
}

model OTP {
  id              String      @id @default(uuid())
  email           String
  codeHash        String
  type            OTPType
  attempts        Int         @default(0)
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
}

model AuditLog {
  id              String      @id @default(uuid())
  userId          String?
  userRole        String?
  action          String
  details         String      @db.Text
  ip              String?
  browser         String?
  device          String?
  timestamp       DateTime    @default(now())
}

model Branch {
  id              String      @id @default(uuid())
  name            String
  address         String      @db.Text
  contact         String
  managerName     String
  googleMapUrl    String?     @db.Text
  imageUrl        String?     @db.Text
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

model News {
  id              String      @id @default(uuid())
  titleEn         String
  titleMr         String
  contentEn       String      @db.LongText
  contentMr       String      @db.LongText
  isPinned        Boolean     @default(false)
  scheduledPublish DateTime?
  status          NewsStatus  @default(PUBLISHED)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum DownloadType {
  ANNUAL_REPORT
  FORM
  GST_CERTIFICATE
  CIRCULAR
  NOTICE
}

model Download {
  id              String       @id @default(uuid())
  titleEn         String
  titleMr         String
  type            DownloadType
  fileUrl         String       @db.Text
  
  createdAt       DateTime     @default(now())
}

model GalleryImage {
  id              String      @id @default(uuid())
  titleEn         String
  titleMr         String
  category        String
  imageUrl        String      @db.Text
  sortingOrder    Int         @default(0)
  isActive        Boolean     @default(true)
  
  createdAt       DateTime    @default(now())
}

model GalleryVideo {
  id              String      @id @default(uuid())
  titleEn         String
  titleMr         String
  youtubeUrl      String      @db.Text
  isFeatured      Boolean     @default(false)
  
  createdAt       DateTime    @default(now())
}

model HomeBanner {
  id              String      @id @default(uuid())
  titleEn         String
  titleMr         String
  subtitleEn      String
  subtitleMr      String
  imageUrl        String      @db.Text
  linkUrl         String?     @db.Text
  isActive        Boolean     @default(true)
  sortingOrder    Int         @default(0)
  
  createdAt       DateTime    @default(now())
}

model CMSSetting {

  // Existing CMSSetting fields remain unchanged

  id              String      @id @default(uuid())
  key             String      @unique
  valueEn         String      @db.LongText
  valueMr         String      @db.LongText
  group           String
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum MessageStatus {
  PENDING
  REPLIED
}

model ContactMessage {
  id              String      @id @default(uuid())
  name            String
  email           String
  phone           String
  subject         String
  message         String      @db.Text
  replyMessage    String?     @db.Text
  isRead          Boolean     @default(false)
  status          MessageStatus @default(PENDING)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum RecipientType {
  EMPLOYEE
  MEMBER
}

enum NotificationType {
  EMAIL
  SMS
  IN_APP
}

model Notification {
  id              String      @id @default(uuid())
  recipientType   RecipientType
  recipientId     String
  title           String
  message         String      @db.Text
  type            NotificationType
  isRead          Boolean     @default(false)
  
  createdAt       DateTime    @default(now())
}

model LoanCalculatorSetting {
  id                  String   @id @default(uuid())
  titleEn             String
  titleMr             String
  subtitleEn          String
  subtitleMr          String
  defaultAmount       Decimal  @db.Decimal(15, 2)
  defaultInterestRate Decimal  @db.Decimal(5, 2)
  defaultTenure       Int
  emiType             String   @default("MONTHLY")
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

enum InterestRateType {
  LOAN
  DEPOSIT
}

model InterestRate {
  id              String      @id @default(uuid())
  type            InterestRateType
  schemeNameEn    String
  schemeNameMr    String
  durationEn      String
  durationMr      String
  rate            Decimal     @db.Decimal(5, 2)
  isActive        Boolean     @default(true)
  sortingOrder    Int         @default(0)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model BoardMember {
  id              String      @id @default(uuid())
  name            String
  designationEn   String
  designationMr   String
  imageUrl        String      @db.Text
  isActive        Boolean     @default(true)
  sortingOrder    Int         @default(0)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Award {
  id              String      @id @default(uuid())
  titleEn         String
  titleMr         String
  year            String
  descriptionEn   String      @db.Text
  descriptionMr   String      @db.Text
  imageUrl        String      @db.Text
  isActive        Boolean     @default(true)
  sortingOrder    Int         @default(0)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model SocialActivity {
  id              String      @id @default(uuid())
  titleEn         String
  titleMr         String
  date            DateTime
  descriptionEn   String      @db.Text
  descriptionMr   String      @db.Text
  imageUrl        String      @db.Text
  isActive        Boolean     @default(true)
  sortingOrder    Int         @default(0)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

